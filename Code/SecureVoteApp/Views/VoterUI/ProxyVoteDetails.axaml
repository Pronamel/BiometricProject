<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:SecureVoteApp.ViewModels"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="380"
            x:Class="SecureVoteApp.Views.VoterUI.ProxyVoteDetailsView"
            x:DataType="vm:ProxyVoteDetailsViewModel">

    <Design.DataContext>
        <vm:ProxyVoteDetailsViewModel/>
    </Design.DataContext>

    <Grid Background="#f6f2e6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.ColumnSpan="2"
                   Text="Proxy Vote Identity Check"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,30"
                   Foreground="#333"/>

        <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
            <StackPanel Spacing="16">
                <TextBlock Text="Represented Voter" FontWeight="Bold" Foreground="#333" FontSize="16"/>

                <StackPanel>
                    <TextBlock Text="First Name" FontWeight="Medium" Foreground="#333" Margin="0,0,0,5"/>
                    <TextBox Width="300" Height="35" Text="{Binding RepresentedFirstName}"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Last Name" FontWeight="Medium" Foreground="#333" Margin="0,0,0,5"/>
                    <TextBox Width="300" Height="35" Text="{Binding RepresentedLastName}"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Date Of Birth" FontWeight="Medium" Foreground="#333" Margin="0,0,0,5"/>
                    <DatePicker Width="300" Height="35" SelectedDate="{Binding RepresentedDateOfBirth}"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Post Code" FontWeight="Medium" Foreground="#333" Margin="0,0,0,5"/>
                    <TextBox Width="300" Height="35" Text="{Binding RepresentedPostCode}"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Town Of Birth" FontWeight="Medium" Foreground="#333" Margin="0,0,0,5"/>
                    <TextBox Width="300" Height="35" Text="{Binding RepresentedTownOfBirth}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
            <StackPanel Spacing="16">
                <TextBlock Text="Proxy Voter" FontWeight="Bold" Foreground="#333" FontSize="16"/>

                <StackPanel>
                    <TextBlock Text="First Name" FontWeight="Medium" Foreground="#333" Margin="0,0,0,5"/>
                    <TextBox Width="300" Height="35" Text="{Binding ProxyFirstName}"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Last Name" FontWeight="Medium" Foreground="#333" Margin="0,0,0,5"/>
                    <TextBox Width="300" Height="35" Text="{Binding ProxyLastName}"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Date Of Birth" FontWeight="Medium" Foreground="#333" Margin="0,0,0,5"/>
                    <DatePicker Width="300" Height="35" SelectedDate="{Binding ProxyDateOfBirth}"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Post Code" FontWeight="Medium" Foreground="#333" Margin="0,0,0,5"/>
                    <TextBox Width="300" Height="35" Text="{Binding ProxyPostCode}"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Town Of Birth" FontWeight="Medium" Foreground="#333" Margin="0,0,0,5"/>
                    <TextBox Width="300" Height="35" Text="{Binding ProxyTownOfBirth}"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="DarkGreen"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Width="300"/>

                <ProgressBar IsIndeterminate="True"
                             IsVisible="{Binding IsLooking}"
                             Width="300"
                             Height="8"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,16,0,0">
                    <Button Content="Back"
                            Width="80"
                            Height="35"
                            Background="LightGray"
                            FontSize="14"
                            Command="{Binding BackCommand}"/>
                    <Button Content="Authenticate >"
                            Width="120"
                            Height="35"
                            Background="Green"
                            Foreground="White"
                            FontSize="14"
                            IsEnabled="{Binding !IsLooking}"
                            Command="{Binding AuthenticateCommand}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>