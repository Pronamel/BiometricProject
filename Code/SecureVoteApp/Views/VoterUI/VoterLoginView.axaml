<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:SecureVoteApp.ViewModels"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
            x:Class="SecureVoteApp.Views.VoterUI.VoterLoginView"
            x:DataType="vm:VoterLoginViewModel">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
            to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:VoterLoginViewModel/>
    </Design.DataContext>

    <Grid Background="#f6f2e6">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="25" Width="400">
            
            <!-- Voter Login Title -->
            <TextBlock Text="Voter Login" 
                       FontSize="32" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center" 
                       Foreground="DarkSlateGray" 
                       Margin="0,0,0,20"/>

            <!-- County Selection Section -->
            <StackPanel Orientation="Horizontal" Spacing="16">
                <!-- County Selection -->
                <StackPanel Width="160" Spacing="8">
                    <TextBlock Text="County" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="DarkSlateGray"/>
                    <ComboBox Name="CountyComboBox"
                              SelectedItem="{Binding SelectedCounty}"
                              ItemsSource="{Binding CountyOptions}"
                              Background="White"
                              BorderBrush="Gray"
                              BorderThickness="2"
                              CornerRadius="5"
                              Padding="10"
                              FontSize="14"
                              Height="40"
                              PlaceholderText="Select County"/>
                </StackPanel>
                <!-- Constituency Selection -->
                <StackPanel Width="220" Spacing="8">
                    <TextBlock Text="Constituency" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="DarkSlateGray"/>
                    <ComboBox Name="ConstituencyComboBox"
                              SelectedItem="{Binding SelectedConstituency}"
                              ItemsSource="{Binding ConstituencyOptions}"
                              Background="White"
                              BorderBrush="Gray"
                              BorderThickness="2"
                              CornerRadius="5"
                              Padding="10"
                              FontSize="14"
                              Height="40"
                              PlaceholderText="Select Constituency"/>
                </StackPanel>
            </StackPanel>

            <!-- Polling Station Code Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Polling Station Code (e.g., STN-042)" 
                           FontSize="16" 
                           FontWeight="SemiBold"
                           Foreground="DarkSlateGray"/>
                <TextBox Name="PollingStationCodeTextBox"
                         Text="{Binding PollingStationCode}"
                         Background="White"
                         BorderBrush="Gray"
                         BorderThickness="2"
                         CornerRadius="5"
                         Padding="10"
                         FontSize="14"
                         Height="40"/>
            </StackPanel>

            <!-- Status Messages Section -->
            <StackPanel Spacing="5">
                <!-- Main Status Message Display -->
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="DarkSlateGray"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"/>

                <!-- Server Status Display -->
                <TextBlock Text="{Binding ServerStatus}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="Gray"
                           Margin="0,5,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Test Connection Button -->
            <Button Command="{Binding TestConnectionCommand}"
                    Content="Test Server Connection"
                    IsEnabled="{Binding !IsConnecting}"
                    Background="#007acc"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    Padding="25,10"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="#005a99"
                    Margin="0,10,0,0"
                    Cursor="Hand">
                <Button.Styles>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Background" Value="#005a99"/>
                    </Style>
                    <Style Selector="Button:disabled">
                        <Setter Property="Background" Value="#cccccc"/>
                        <Setter Property="Foreground" Value="#666666"/>
                        <Setter Property="BorderBrush" Value="#999999"/>
                    </Style>
                </Button.Styles>
            </Button>

            <!-- Continue Button -->
            <Button Command="{Binding ContinueCommand}"
                    Content="Continue"
                    Background="#0bac02"
                    Foreground="White"
                    FontSize="16"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    Padding="40,12"
                    CornerRadius="8"
                    BorderThickness="2"
                    BorderBrush="#000000"
                    Margin="0,20,0,0"
                    Cursor="Hand">
                <Button.Styles>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Background" Value="#098a02"/>
                    </Style>
                </Button.Styles>
            </Button>

        </StackPanel>
    </Grid>
</UserControl>