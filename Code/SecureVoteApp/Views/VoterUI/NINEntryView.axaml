<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:SecureVoteApp.ViewModels"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="380"
            x:Class="SecureVoteApp.Views.VoterUI.NINEntryView"
            x:DataType="vm:NINEntryViewModel">

    
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
            to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:NINEntryViewModel/>
    </Design.DataContext>

    <Grid Background="#f6f2e6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <TextBlock Grid.ColumnSpan="2" 
                   Text="Enter Voter Details" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center"
                   Margin="0,20,0,30" 
                   Foreground="#333"/>

        <!-- Left Grid -->
        <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
             
            <StackPanel Spacing="15">
                <StackPanel IsVisible="{Binding DateOfBirthVisible}">
                    <TextBlock Text="First Name (e.g., John):" 
                               FontWeight="Medium" 
                               Foreground="#333" 
                               Margin="0,35,0,5"/>
                    <TextBox Width="300" Height="35" Text="{Binding FirstName}" IsEnabled="{Binding !IsLooking}"/>
                </StackPanel>

                <StackPanel IsVisible="{Binding DateOfBirthVisible}">
                    <TextBlock Text="Last Name (e.g., Smith):" 
                               FontWeight="Medium" 
                               Foreground="#333" 
                               Margin="0,0,0,5"/>
                    <TextBox Width="300" Height="35" Text="{Binding LastName}" IsEnabled="{Binding !IsLooking}"/>
                </StackPanel>
                
                <StackPanel IsVisible="{Binding DateOfBirthVisible}">
                    <TextBlock Text="Date of Birth (e.g., 1985-11-23):" 
                               FontWeight="Medium" 
                               Foreground="#333" 
                               Margin="0,0,0,5"/>
                    <TextBox Width="300" Height="35" Text="{Binding DateOfBirth}" IsEnabled="{Binding !IsLooking}"/>
                </StackPanel>

                <StackPanel IsVisible="{Binding ShowNinOnly}">
                    <TextBlock Text="National Insurance Number (e.g., AB123456C)" 
                               FontWeight="Medium" 
                               Foreground="#333" 
                               Margin="0,35,0,5"/>
                    <TextBox Width="300" Height="35" Text="{Binding NationalInsuranceNumber}" IsEnabled="{Binding !IsLooking}" />
                </StackPanel>

                <StackPanel>
                    <Button Content="{Binding BlueTextHave}" 
                            Width="300" 
                            Height="30"
                            Background="transparent"
                            FontSize="12"
                            Margin="-5,-15,0,0"
                            Foreground="skyblue"
                            Command="{Binding BlueTextPressCommand}"
                            IsEnabled="{Binding !IsLooking}"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="14"
                           FontWeight="Bold"
                           Padding="5"
                           Foreground="#2ecc71"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="20" Margin="0,30,0,0">
                    <Button Content="Back" 
                            Width="50" 
                            Height="35"
                            Background="LightGray"
                            FontSize="14"
                            Command="{Binding BackCommand}"
                            IsEnabled="{Binding !IsLooking}"/>
                    <Button Content="Authenticate" 
                            Width="110" 
                            Height="35"
                            Background="Green"
                            Foreground="White"
                            FontSize="14"
                            Command="{Binding ContinueCommand}"
                            IsEnabled="{Binding !IsLooking}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>

    
        



</UserControl>