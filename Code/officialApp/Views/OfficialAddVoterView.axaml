<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:officialApp.ViewModels"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="1325" d:DesignHeight="1788"
            x:Class="officialApp.Views.OfficialAddVoterView"
            x:DataType="vm:OfficialAddVoterViewModel">

    <Design.DataContext>
        <vm:OfficialAddVoterViewModel/>
    </Design.DataContext>

    <Grid Background="#f6f2e6">
        <ScrollViewer>
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Stretch" Spacing="15" Margin="20">
            <TextBlock Text="Create User"
                      FontSize="28"
                      FontWeight="Bold"
                      Foreground="black"
                      HorizontalAlignment="Center"/>

            <TextBlock Text="Choose user type, complete fields, scan fingerprint, then submit."
                      TextWrapping="Wrap"
                      Foreground="#555555"
                      FontSize="14"
                      HorizontalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                <Button Content="Create Voter"
                        Width="160"
                        Height="42"
                        FontSize="14"
                        FontWeight="Bold"
                    Command="{Binding SwitchToCreateVoterModeCommand}"
                    Background="#d97509"
                    Foreground="White"/>

                <Button Content="Create Official"
                        Width="160"
                        Height="42"
                        FontSize="14"
                        FontWeight="Bold"
                    Command="{Binding SwitchToCreateOfficialModeCommand}"
                    Background="#6b4423"
                    Foreground="White"/>
            </StackPanel>

            <Separator Background="#ddd" Height="2" Margin="0,10,0,10"/>

            <Grid ColumnDefinitions="2*,*" ColumnSpacing="24">
                <StackPanel Grid.Column="0" Spacing="10" Margin="20,0,20,20">
                    <Border IsVisible="{Binding IsCreateVoterMode}"
                            Background="#ece6d6"
                            BorderBrush="#d9c8a9"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Voter Details" FontSize="16" FontWeight="Bold" Foreground="black"/>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Text="First Name (e.g., John)" Foreground="black" FontSize="14"/>
                                <TextBox Text="{Binding FirstName}" Height="40" FontSize="14" Padding="10"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="5">
                                <TextBlock Text="Last Name (e.g., Smith)" Foreground="black" FontSize="14"/>
                                <TextBox Text="{Binding LastName}" Height="40" FontSize="14" Padding="10"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Text="National Insurance Number (optional, e.g., AB123456C)" Foreground="black" FontSize="14"/>
                                <TextBox Text="{Binding NationalInsuranceNumber}" Height="40" FontSize="14" Padding="10"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="5">
                                <TextBlock Text="Date of Birth" Foreground="black" FontSize="14"/>
                                <DatePicker SelectedDate="{Binding SelectedDateOfBirth}" Height="40" FontSize="14"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Town Of Birth (e.g., London)" Foreground="black" FontSize="14"/>
                            <TextBox Text="{Binding TownOfBirth}" Height="40" FontSize="14" Padding="10"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Address Line 1 (e.g., 123 High Street)" Foreground="black" FontSize="14"/>
                            <TextBox Text="{Binding AddressLine1}" Height="40" FontSize="14" Padding="10"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Address Line 2 (e.g., Flat 5)" Foreground="black" FontSize="14"/>
                            <TextBox Text="{Binding AddressLine2}" Height="40" FontSize="14" Padding="10"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,2*" ColumnSpacing="24">
                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Text="Post Code (e.g., SW1A 1AA)" Foreground="black" FontSize="14"/>
                                <TextBox Text="{Binding PostCode}" Height="40" FontSize="14" Padding="10"/>
                            </StackPanel>

                            <Grid Grid.Column="1" ColumnDefinitions="*,*" ColumnSpacing="8">
                                <StackPanel Grid.Column="0" Spacing="5">
                                    <TextBlock Text="County" Foreground="black" FontSize="14"/>
                                    <ComboBox SelectedItem="{Binding SelectedCounty}"
                                              ItemsSource="{Binding CountyOptions}"
                                              Height="40"
                                              FontSize="14"
                                              PlaceholderText="Select county"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="5">
                                    <TextBlock Text="Constituency" Foreground="black" FontSize="14"/>
                                    <ComboBox SelectedItem="{Binding SelectedConstituency}"
                                              ItemsSource="{Binding ConstituencyOptions}"
                                              Height="40"
                                              FontSize="14"
                                              PlaceholderText="Select constituency"/>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        </StackPanel>
                    </Border>

                    <Border IsVisible="{Binding IsCreateOfficialMode}"
                            Background="#ece6d6"
                            BorderBrush="#d9c8a9"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Official Details" FontSize="16" FontWeight="Bold" Foreground="black"/>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Username (e.g., official.j.smith)" Foreground="black" FontSize="14"/>
                            <TextBox Text="{Binding OfficialUsername}"
                                    Height="40"
                                    FontSize="14"
                                    Padding="10"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Password (e.g., SecurePass!2026)" Foreground="black" FontSize="14"/>
                            <TextBox Text="{Binding Password}"
                                    Height="40"
                                    FontSize="14"
                                    Padding="10"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Polling Station" Foreground="black" FontSize="14"/>
                            <ComboBox SelectedItem="{Binding SelectedPollingStation}"
                                      ItemsSource="{Binding PollingStationOptions}"
                                      Height="40"
                                      FontSize="14"
                                      PlaceholderText="Select polling station"/>
                        </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="10">
                    <TextBlock Text="Fingerprint Capture" FontSize="16" FontWeight="Bold" Foreground="black" HorizontalAlignment="Center" TextAlignment="Center"/>

                    <Button Content="Start Scanning"
                            Background="Blue"
                            Foreground="White"
                            Width="150"
                            Height="40"
                            FontSize="14"
                            FontWeight="Bold"
                            HorizontalAlignment="Center"
                            Command="{Binding StartScanningCommand}"
                            IsEnabled="{Binding !IsCapturing}"/>

                    <Panel Background="Black"
                           Width="250"
                           Height="250"
                           HorizontalAlignment="Center">
                        <Image Source="{Binding PreviewImage}"
                               Width="250"
                               Height="250"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"/>
                    </Panel>

                    <TextBlock Text="{Binding CaptureStatusMessage}"
                               FontSize="12"
                               Foreground="#333"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Width="280"/>

                    <ProgressBar IsIndeterminate="True"
                                 IsVisible="{Binding IsCapturing}"
                                 Width="250"
                                 Height="8"
                                 HorizontalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button 
                            Command="{Binding SubmitCommand}"
                            Background="#27ae60"
                            Width="120"
                            Height="50"
                            BorderThickness="2"
                            BorderBrush="Black"
                            FontSize="16">
                            <TextBlock Text="Submit" Foreground="white"/>
                        </Button>

                        <Button 
                            Command="{Binding CancelCommand}"
                            Background="#e74c3c"
                            Width="120"
                            Height="50"
                            BorderThickness="2"
                            BorderBrush="Black"
                            FontSize="16">
                            <TextBlock Text="Cancel" Foreground="white"/>
                        </Button>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Place finger on the scanner"
                                   FontSize="16"
                                   Foreground="Black"
                                   HorizontalAlignment="Center"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Press lightly and hold for 3 seconds"
                                   FontSize="12"
                                   Foreground="Black"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock x:Name="StatusMessage"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               Foreground="{Binding StatusColor}"
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
            </StackPanel>
        </ScrollViewer>

        <Button Content="← Back"
            Command="{Binding CancelCommand}"
            Padding="10,5"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="10"
            Background="#E0E0E0"
            Foreground="Black"/>
    </Grid>
</UserControl>
