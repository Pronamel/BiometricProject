<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:officialApp.ViewModels"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="380"
            x:Class="officialApp.Views.OfficialAuthenticateView"
            x:DataType="vm:OfficialAuthenticateViewModel">

    
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
            to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:OfficialAuthenticateViewModel/>
    </Design.DataContext>


    <Grid Background="#f6f2e6">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
            <!-- Device Status with Refresh -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                <TextBlock Text="{Binding DeviceStatus}"
                        FontSize="14"
                        Foreground="DarkGreen"
                        HorizontalAlignment="Center"
                        FontWeight="Bold"
                        VerticalAlignment="Center"/>
                <Button Content="Refresh" 
                        Background="Gray" 
                        Foreground="White"
                        Width="60" 
                        Height="28"
                        FontSize="12"
                        Command="{Binding RefreshScannerStatusCommand}"/>
            </StackPanel>

            <!-- Capture Status Message -->
            <TextBlock Text="{Binding CaptureStatusMessage}"
                    FontSize="14"
                    Foreground="DarkBlue"
                    HorizontalAlignment="Center"
                    FontWeight="Bold"/>

            <!-- Quality Score Display -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                <TextBlock Text="Quality:"
                        FontSize="14"
                        Foreground="Black"
                        VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding QualityScore}"
                            FontSize="18"
                            Foreground="DarkGreen"
                            FontWeight="Bold"/>
                    <TextBlock Text="%"
                            FontSize="18"
                            Foreground="DarkGreen"
                            FontWeight="Bold"/>
                </StackPanel>
                <TextBlock Text="(need 10%)"
                        FontSize="12"
                        Foreground="Gray"
                        VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Start Scanning Button -->
            <Button Content="Start Scanning"
                    Background="Blue"
                    Foreground="White"
                    Width="150"
                    Height="40"
                    FontSize="14"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    Command="{Binding StartScanningCommand}"
                    IsEnabled="{Binding !IsCapturing}"/>

            <!-- Live Preview Image -->
            <Panel Background="Black" 
                   Width="250"
                   Height="250"
                   HorizontalAlignment="Center">
                <Image Source="{Binding PreviewImage}"
                    Width="250"
                    Height="250"
                    Stretch="Uniform"
                    HorizontalAlignment="Center"/>
            </Panel>

            <!-- Original test buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                <Button Content="Fail Scan" 
                        Background="Red" 
                        Foreground="White"
                        Width="100" 
                        Height="40"
                        FontSize="14"
                        FontWeight="Bold"
                        Command="{Binding ScanFingerPrintInvalidCommand}"
                        IsEnabled="{Binding !IsCapturing}"/>

                <Button Content="Good Scan" 
                        Background="Green" 
                        Foreground="White"
                        Width="100" 
                        Height="40"
                        FontSize="14"
                        FontWeight="Bold"
                        Command="{Binding ScanFingerPrintValidCommand}"
                        IsEnabled="{Binding !IsCapturing}"/>

                <Button Content="Test Image" 
                        Background="Orange" 
                        Foreground="White"
                        Width="100" 
                        Height="40"
                        FontSize="14"
                        FontWeight="Bold"
                        Command="{Binding TestPreviewImageCommand}"
                        ToolTip.Tip="Display test fingerprint image"/>
            </StackPanel>
            
            <Image Source="{Binding ImageSource}"
                Width="180"
                Height="180"
                Stretch="Uniform"/>
            <StackPanel>   
                <TextBlock Text="Place finger on the scanner"
                        FontSize="35"
                        Foreground="Black"
                        HorizontalAlignment="Center"/>
                <TextBlock Text="Press lightly and hold for 3 seconds" 
                        FontSize="20"
                        Foreground="Black"
                        HorizontalAlignment="Center"/>

                <TextBlock Text="{Binding StatusMessage}" 
                        FontSize="18"
                        Foreground="red"
                        HorizontalAlignment="Center"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>